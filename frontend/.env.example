# Hybrid Data Layer configuration
# Copy to .env.local and adjust as needed.

# When false (or unset), the app always uses mock data — no backend calls at all.
VITE_USE_BACKEND=false

# Django backend base URL (only used when VITE_USE_BACKEND=true)
VITE_API_BASE_URL=http://localhost:8000

# OpenRouter (used by the future Django AI endpoints, not called directly from the frontend)
VITE_OPENROUTER_URL=https://openrouter.ai/api/v1
VITE_OPENROUTER_KEY=
