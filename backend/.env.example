DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
# Option A: Neon (or any hosted Postgres) — set this and DB_* below are ignored
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# Option B: local/docker Postgres (used only if DATABASE_URL is empty)
DB_NAME=talentforge
DB_USER=talentforge
DB_PASSWORD=talentforge
DB_HOST=db
DB_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
CLOUDINARY_URL=
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_KEY=
